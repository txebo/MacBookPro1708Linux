prefix_rule(pattern=["git", "remote", "add", "origin", "https://github.com/txebo/mtc.git"], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "origin"], decision="allow")
prefix_rule(pattern=["git", "add", "."], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "add", "src/core/telegram/TDLibAdapter.h", "src/core/telegram/TDLibAdapter.cpp", "src/ui/MainWindow.cpp"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m"], decision="allow")
prefix_rule(pattern=["git", "remote", "set-url", "origin", "git@github.com:txebo/mtc.git"], decision="allow")
prefix_rule(pattern=["timeout", "20", "ssh", "-o", "StrictHostKeyChecking=accept-new", "-T", "git@github.com"], decision="allow")
prefix_rule(pattern=["ssh-add", "-l"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "for s in /tmp/ssh-*/agent.*; do [ -S \"$s\" ] || continue; echo \"SOCK=$s\"; SSH_AUTH_SOCK=\"$s\" ssh-add -l 2>&1; done"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "SSH_AUTH_SOCK=/tmp/ssh-ILbowrZTXkmJ/agent.93074 git push"], decision="allow")
prefix_rule(pattern=["./build/mtc"], decision="allow")
prefix_rule(pattern=["systemctl", "is-active", "bluetooth"], decision="allow")
prefix_rule(pattern=["hciconfig", "-a"], decision="allow")
prefix_rule(pattern=["ln", "-sfn"], decision="allow")
prefix_rule(pattern=["sudo", "ln", "-sfn"], decision="allow")
